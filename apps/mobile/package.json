{
  "name": "@ai-cal/mobile",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor": "node ./scripts/doctor-gate.mjs",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "CI=1 bunx expo config --type public >/dev/null",
    "check-all": "bun run lint && bun run typecheck && bun run test && bun run build",
    "verify": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "expo": "^55.0.4",
    "expo-constants": "~55.0.7",
    "expo-image-manipulator": "^55.0.9",
    "expo-image-picker": "~55.0.11",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-secure-store": "^55.0.8",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "zod": "^4.1.7"
  },
  "devDependencies": {
    "@jridgewell/gen-mapping": "^0.3.13",
    "@types/react": "~19.2.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  }
}
