{
  "name": "ai-calories-tracker",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "api:dev": "cd apps/api && bun run dev",
    "api:deploy": "cd apps/api && bun run deploy",
    "api:deploy:script": "bun run check-all && bun run api:deploy",
    "api:lint": "cd apps/api && bun run lint",
    "api:verify": "cd apps/api && bun run verify",
    "api:build": "cd apps/api && bun run build",
    "api:smoke:local": "cd apps/api && bun run smoke:local",
    "api:verify:production": "cd apps/api && bun run verify:production",
    "api:verify:production:loop": "cd apps/api && bun run verify:production:loop",
    "mobile:start": "cd apps/mobile && bun run start",
    "mobile:lint": "cd apps/mobile && bun run lint",
    "mobile:build": "cd apps/mobile && bun run build",
    "mobile:verify": "cd apps/mobile && bun run verify",
    "lint": "bun run api:lint && bun run mobile:lint",
    "verify": "bun run api:verify && bun run mobile:verify",
    "build": "bun run api:build && bun run mobile:build",
    "smoke:local": "bun run api:smoke:local",
    "check-all": "bun run lint && bun run verify && bun run build && bun run smoke:local",
    "verify:autonomous": "bash ./scripts/verify-autonomous.sh"
  }
}
